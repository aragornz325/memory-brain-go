# Puerto de escucha del servidor API HTTP
SERVER_PORT=3210

# Configuración de base de datos PostgreSQL con soporte pgvector
POSTGRES_HOST_MEMORY_BRAIN=localhost
POSTGRES_PORT_MEMORY_BRAIN=5432
POSTGRES_USER_MEMORY_BRAIN=memory_brain
POSTGRES_PASSWORD_MEMORY_BRAIN=memory_brain
POSTGRES_DB_MEMORY_BRAIN=memory_brain
DB_LOGGING_MEMORY_BRAIN=true

# Url y modelo de Ollama para generación de embeddings semánticos
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Configuración del CLI y seguridad
MEMORY_BRAIN_URL=http://localhost:3210
MEMORY_BRAIN_API_KEY=
MEMORY_BRAIN_WORKSPACE=
MEMORY_BRAIN_PROJECT=
